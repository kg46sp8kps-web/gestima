{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "frontend"
    },
    {
      "name": "backend",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "uvicorn", "app.gestima_app:app", "--reload", "--reload-dir", "app", "--host", "0.0.0.0", "--port", "8000"],
      "port": 8000
    }
  ]
}
